<Window x:Class="CarRental.EditBookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CarRental"
        Title="Редактировать бронь" Height="560" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <DataTemplate DataType="{x:Type local:Car}">
            <Border Padding="8,6" Margin="0,2" BorderBrush="#B0BEC5" BorderThickness="1"
                    CornerRadius="4" Background="#FAFAFA" SnapsToDevicePixels="True"
                    Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FAFAFA"/>
                        <Setter Property="BorderBrush" Value="#B0BEC5"/>
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.35"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         From="0.9" To="1" Duration="0:0:0.35"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         From="0.9" To="1" Duration="0:0:0.35"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <DataTrigger Binding="{Binding IsFree}" Value="True">
                                <Setter Property="Background" Value="#E8F5E9"/>
                                <Setter Property="BorderBrush" Value="#66BB6A"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsFree}" Value="False">
                                <Setter Property="Opacity" Value="0.75"/>
                            </DataTrigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C8E6C9"/>
                                <Setter Property="BorderBrush" Value="#2E7D32"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontWeight="Bold" FontSize="14">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="Make" Mode="OneWay"/>
                                    <Binding Path="Model" Mode="OneWay"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Foreground="#37474F" FontSize="13">
                            <TextBlock.Text>
                                <Binding Path="PricePerDay" Mode="OneWay" StringFormat="{}{0:N0} BYN/сут"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="{Binding Class, Mode=OneWay}" FontSize="11" HorizontalAlignment="Right" Foreground="#607D8B"/>
                        <TextBlock FontSize="11" HorizontalAlignment="Right" Foreground="#607D8B">
                            <TextBlock.Text>
                                <Binding Path="PassengerSeats" Mode="OneWay" StringFormat="{}{0} мест"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Фильтр списка" FontWeight="Bold" Margin="0,0,0,6"/>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="Класс:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="0" Grid.Column="1" Margin="8,0,0,6"
                      SelectedIndex="{Binding FilterClassIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Content="Все классы"/>
                <ComboBoxItem Content="Эконом"/>
                <ComboBoxItem Content="Стандарт"/>
                <ComboBoxItem Content="Премиум"/>
                <ComboBoxItem Content="Люкс"/>
            </ComboBox>

            <Label Grid.Row="1" Grid.Column="0" Content="Мин. мест:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,6"
                      ItemsSource="{Binding SeatThresholdOptions, Mode=OneWay}"
                      SelectedItem="{Binding MinPassengerSeats, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                      Content="Только автомобили со свободной единицей в парке (по текущим броням)"
                      IsChecked="{Binding OnlyWithAvailableFleet, Mode=TwoWay}"/>
        </Grid>

        <Label Grid.Row="2" Content="Автомобиль:"/>
        <ListBox Grid.Row="3" MinHeight="140" MaxHeight="200"
                 ItemsSource="{Binding CarsView}"
                 SelectedItem="{Binding SelectedCar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 BorderThickness="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

        <Label Grid.Row="4" Content="Клиент:" Margin="0,10,0,0"/>
        <TextBox Grid.Row="5" Margin="0,4,0,10"
                 Text="{Binding ClientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <Grid Grid.Row="6" Margin="0,0,0,10" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <Label Content="Дата начала"/>
                <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <Label Content="Дата окончания"/>
                <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="7" BorderBrush="#CFD8DC" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,8" Orientation="Horizontal">
                    <TextBlock Text="Стоимость аренды (расчёт): " FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RentalCostDisplay, Mode=OneWay}"
                               FontSize="15" FontWeight="Bold" Foreground="#1565C0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="100" Margin="0,0,8,0" IsDefault="True" Click="Save_Click"/>
                    <Button Content="Закрыть" Width="90" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
