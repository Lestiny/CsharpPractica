<Window x:Class="CarRental.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CarRental"
        Title="Аренда автомобилей" Height="810" Width="1120"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <DataTemplate x:Key="CarCardTemplate" DataType="{x:Type local:CarModel}">
            <Border Padding="8,6" Margin="0,2"
                    CornerRadius="4"
                    Background="#FAFAFA"
                    BorderBrush="#B0BEC5"
                    BorderThickness="1"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FAFAFA"/>
                        <Setter Property="BorderBrush" Value="#B0BEC5"/>
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.45">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         From="0.85" To="1" Duration="0:0:0.45">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         From="0.85" To="1" Duration="0:0:0.45">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>

                            <DataTrigger Binding="{Binding OccupiedCount}" Value="0">
                                <Setter Property="Background" Value="#A5D6A7"/>
                                <Setter Property="BorderBrush" Value="#1B5E20"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsPartiallyOccupied}" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="BorderBrush" Value="#616161"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsFullyOccupied}" Value="True">
                                <Setter Property="Background" Value="#EF9A9A"/>
                                <Setter Property="BorderBrush" Value="#B71C1C"/>
                            </DataTrigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontWeight="Bold" FontSize="14"
                                   Text="{Binding DisplayName}"/>
                        <TextBlock Foreground="#37474F" FontSize="13"
                                   Text="{Binding PricePerDay, StringFormat='{}{0:N0} BYN/сут'}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Border Padding="6,1" CornerRadius="3" Margin="0,0,0,4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#BDBDBD"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OccupiedCount}" Value="0">
                                            <Setter Property="Background" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPartiallyOccupied}" Value="True">
                                            <Setter Property="Background" Value="#757575"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsFullyOccupied}" Value="True">
                                            <Setter Property="Background" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Foreground="White" FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Частично"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OccupiedCount}" Value="0">
                                                <Setter Property="Text" Value="Свободно"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFullyOccupied}" Value="True">
                                                <Setter Property="Text" Value="Занято"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock FontSize="11" HorizontalAlignment="Right" Foreground="#607D8B"
                                   Text="{Binding FleetSize, StringFormat='{}{0} в парке'}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="BookButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#2E7D32"
                                CornerRadius="4"
                                BorderBrush="#1B5E20"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             From="1" To="1.1" Duration="0:0:0.12" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             From="1" To="1.1" Duration="0:0:0.12" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.85" Duration="0:0:0.12" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Setter TargetName="Bd" Property="Background" Value="#388E3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             From="1.1" To="1.2" Duration="0:0:0.09" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             From="1.1" To="1.2" Duration="0:0:0.09" AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.8" Duration="0:0:0.09" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Setter TargetName="Bd" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2.7*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="18" FontWeight="Bold" Text="Приложение аренды автомобилей" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Оформление аренды" Margin="0,0,14,10">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Top" Text="Автомобили:" Margin="0,2,6,4" HorizontalAlignment="Right"/>
                <ListView Grid.Row="0" Grid.Column="1"
                          MinHeight="120" MaxHeight="170"
                          ItemsSource="{Binding Cars}"
                          SelectedItem="{Binding SelectedCar, Mode=TwoWay}"
                          ItemTemplate="{StaticResource CarCardTemplate}"
                          BorderThickness="1"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.CanContentScroll="False"
                          VirtualizingStackPanel.ScrollUnit="Pixel"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,6,0" Text="Клиент:" HorizontalAlignment="Right"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding ClientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,6,0" Text="Дата начала:" HorizontalAlignment="Right"/>
                <DatePicker Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" SelectedDate="{Binding StartDate, Mode=TwoWay}" HorizontalAlignment="Left" Width="160"/>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,6,0" Text="Дата конца:" HorizontalAlignment="Right"/>
                <DatePicker Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" SelectedDate="{Binding EndDate, Mode=TwoWay}" HorizontalAlignment="Left" Width="160"/>

                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,14,0,6" HorizontalAlignment="Left">
                    <Button Content="Забронировать" Width="130"
                            Command="{Binding RentCarCommand}"
                            Style="{StaticResource BookButtonStyle}"/>
                    <Button Content="Вернуть авто" Width="130" Margin="8,0,0,0" Command="{Binding ReturnCarCommand}"/>
                    <ProgressBar Width="140" Height="14" Margin="14,6,0,0" IsIndeterminate="True" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <GroupBox Grid.Row="5" Grid.ColumnSpan="2" Header="Текущие аренды" Margin="0,10,0,0">
                    <ListView ItemsSource="{Binding ActiveRentals}"
                              SelectedItem="{Binding SelectedRental, Mode=TwoWay}"
                              MinHeight="220">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Автомобиль" DisplayMemberBinding="{Binding CarName}" Width="190"/>
                                <GridViewColumn Header="Клиент" DisplayMemberBinding="{Binding ClientName}" Width="130"/>
                                <GridViewColumn Header="Начало" DisplayMemberBinding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                <GridViewColumn Header="Окончание" DisplayMemberBinding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                <GridViewColumn Header="Дней" DisplayMemberBinding="{Binding Days}" Width="55"/>
                                <GridViewColumn Header="Итог" Width="110"
                                                DisplayMemberBinding="{Binding TotalCost, StringFormat={}{0:N0} BYN}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="1" Header="Аккаунт" Margin="0,0,0,10" VerticalAlignment="Top">
            <Border Margin="10" Padding="12"
                    Background="#F3F6FF"
                    BorderBrush="#90CAF9"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="17" Background="#1976D2" Margin="0,0,10,0">
                            <TextBlock Text="👤" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Текущий аккаунт" Foreground="#546E7A" FontSize="11"/>
                            <TextBlock Text="{Binding CurrentUserDisplay}" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Grid.Row="1" Margin="0,12,0,12" Background="#BBDEFB"/>

                    <Button Grid.Row="2"
                            Padding="10,6"
                            Content="Выйти из аккаунта"
                            HorizontalAlignment="Stretch"
                            Click="LogoutAndRelogin_Click"/>
                </Grid>
            </Border>
        </GroupBox>

        <GroupBox Grid.Row="2" Grid.ColumnSpan="2" Header="Чат клиент-менеджер">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox Grid.Row="0" ItemsSource="{Binding ChatMessages}"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox Width="720" Text="{Binding ChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Отправить" Width="120" Margin="8,0,0,0" Command="{Binding SendChatCommand}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" FontWeight="SemiBold" Margin="0,8,0,0"/>
    </Grid>
</Window>
