<Window x:Class="CarRental.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CarRental"
        Title="Аренда автомобилей" Height="730" Width="930"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="18" FontWeight="Bold" Text="Приложение аренды автомобилей" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Оформление аренды" Margin="0,0,10,10">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Автомобиль:"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AvailableCars}" SelectedItem="{Binding SelectedCar, Mode=TwoWay}" DisplayMemberPath="DisplayName"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0" Text="Клиент:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding ClientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0" Text="Дата начала:"/>
                <DatePicker Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" SelectedDate="{Binding StartDate, Mode=TwoWay}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,8,0,0" Text="Дата конца:"/>
                <DatePicker Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" SelectedDate="{Binding EndDate, Mode=TwoWay}"/>

                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,8">
                    <Button Content="Арендовать" Width="130" Command="{Binding RentCarCommand}"/>
                    <Button Content="Вернуть авто" Width="130" Margin="8,0,0,0" Command="{Binding ReturnCarCommand}"/>
                    <ProgressBar Width="120" Height="14" Margin="10,6,0,0" IsIndeterminate="True" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <GroupBox Grid.Row="5" Grid.ColumnSpan="2" Header="Текущие аренды" Margin="0,4,0,0">
                    <ListView ItemsSource="{Binding ActiveRentals}" SelectedItem="{Binding SelectedRental, Mode=TwoWay}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Автомобиль" DisplayMemberBinding="{Binding CarName}" Width="190"/>
                                <GridViewColumn Header="Клиент" DisplayMemberBinding="{Binding ClientName}" Width="130"/>
                                <GridViewColumn Header="Начало" DisplayMemberBinding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                <GridViewColumn Header="Окончание" DisplayMemberBinding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                <GridViewColumn Header="Дней" DisplayMemberBinding="{Binding Days}" Width="55"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="1" Header="Локальная авторизация" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock Text="{Binding CurrentUserDisplay}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Логин"/>
                <TextBox Text="{Binding AuthUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Пароль" Margin="0,8,0,0"/>
                <TextBox Text="{Binding AuthPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Роль" Margin="0,8,0,0"/>
                <ComboBox SelectedValue="{Binding SelectedRole, Mode=TwoWay}" SelectedValuePath="Tag">
                    <ComboBoxItem Content="Клиент" Tag="{x:Static local:UserRole.Client}"/>
                    <ComboBoxItem Content="Менеджер" Tag="{x:Static local:UserRole.Manager}"/>
                </ComboBox>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Left">
                    <Button Content="Регистрация" Width="90" Padding="8,4,8,4" Command="{Binding RegisterCommand}"/>
                    <Button Content="Войти" Width="76" Padding="8,4,8,4" Margin="4,0,0,0" Command="{Binding LoginCommand}"/>
                    <Button Content="Выйти" Width="76" Padding="8,4,8,4" Margin="4,0,0,0" Command="{Binding LogoutCommand}"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Grid.ColumnSpan="2" Header="Чат клиент-менеджер (Named Pipes)">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox Grid.Row="0" ItemsSource="{Binding ChatMessages}"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox Width="720" Text="{Binding ChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Отправить" Width="120" Margin="8,0,0,0" Command="{Binding SendChatCommand}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" FontWeight="SemiBold" Margin="0,8,0,0"/>
    </Grid>
</Window>
