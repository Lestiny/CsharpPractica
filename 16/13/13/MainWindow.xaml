<Window x:Class="CarRental.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Аренда автомобилей" Height="500" Width="820"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="18" FontWeight="Bold" Text="Приложение аренды автомобилей" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Автомобиль:"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding AvailableCars}"
                  SelectedItem="{Binding SelectedCar, Mode=TwoWay}"
                  DisplayMemberPath="DisplayName"/>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0" Text="Клиент:"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0"
                 Text="{Binding ClientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0" Text="Дата начала:"/>
        <DatePicker Grid.Row="3" Grid.Column="1" Margin="0,10,0,0"
                    SelectedDate="{Binding StartDate, Mode=TwoWay}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0" Text="Дата конца:"/>
        <DatePicker Grid.Row="4" Grid.Column="1" Margin="0,10,0,0"
                    SelectedDate="{Binding EndDate, Mode=TwoWay}"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,10">
            <Button Content="Арендовать" Width="130" Command="{Binding RentCarCommand}"/>
            <Button Content="Вернуть авто" Width="130" Margin="8,0,0,0" Command="{Binding ReturnCarCommand}"/>
            <TextBlock Margin="16,4,0,0" FontWeight="SemiBold" Text="{Binding StatusMessage}"/>
            <ProgressBar Width="140" Height="14" Margin="10,6,0,0"
                         IsIndeterminate="True" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>

        <GroupBox Grid.Row="6" Grid.ColumnSpan="2" Header="Текущие аренды" Margin="0,4,0,0">
            <ListView ItemsSource="{Binding ActiveRentals}"
                      SelectedItem="{Binding SelectedRental, Mode=TwoWay}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Автомобиль" DisplayMemberBinding="{Binding CarName}" Width="200"/>
                        <GridViewColumn Header="Клиент" DisplayMemberBinding="{Binding ClientName}" Width="180"/>
                        <GridViewColumn Header="Начало" DisplayMemberBinding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                        <GridViewColumn Header="Окончание" DisplayMemberBinding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                        <GridViewColumn Header="Дней" DisplayMemberBinding="{Binding Days}" Width="60"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
    </Grid>
</Window>
